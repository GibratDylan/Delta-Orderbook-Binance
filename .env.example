# Runtime
DRY_RUN=true
LOG_LEVEL=INFO

# Strategy
DELTA_THRESHOLD=0.9
MAX_SPREAD_PCT=0.08
MAX_LONG_POSITIONS=1
ORDER_QTY=0.004
REDUCED_ORDER_QTY=0.003
HOLD_SECONDS=120
DECISION_INTERVAL_SECONDS=0.25
MAX_DATA_AGE_SECONDS=2.0
ORDERBOOK_DEPTH=20
PRIMARY_TOPIC=orderbook.50.BTCUSDC

# Streams
BYBIT_PUBLIC_WS_URL=wss://stream.bybit.com/v5/public/spot
BYBIT_LINEAR_WS_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_TOPICS=orderbook.50.BTCUSDC,orderbook.50.BTCUSDT
BYBIT_LINEAR_TOPICS=orderbook.1.BTCUSDT
BINANCE_WS_URL=wss://stream.binance.com:9443/stream?streams=btcusdt@depth20@100ms/btcfdusd@depth20@100ms
RECONNECT_BASE_SECONDS=0.5
RECONNECT_MAX_SECONDS=20.0
RECONNECT_JITTER_SECONDS=0.5
RECV_TIMEOUT_SECONDS=60.0

# Execution (required only when DRY_RUN=false)
EXECUTION_EXCHANGE=binance
TRADING_SYMBOL=BTCFDUSD
BINANCE_API_KEY=
BINANCE_API_SECRET=
